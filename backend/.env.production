# ─── Backend Production Environment ─────────────────────────────────────────
# SECURITY: Never commit real secrets. Replace all placeholder values.

NODE_ENV=production
PORT=5000

# Database
DB_USER=prod_user
DB_PASS=REPLACE_WITH_SECURE_PASSWORD
DB_NAME=math_intel_dashboard
DATABASE_URL=postgresql://prod_user:REPLACE_WITH_SECURE_PASSWORD@db:5432/math_intel_dashboard

# Auth
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# CORS — set to your actual frontend domain in production
FRONTEND_URL=https://yourdomain.com

# OpenAI — used by AI Coach v2 and insight generation
OPENAI_API_KEY=REPLACE_WITH_YOUR_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini
