# Backend production env template (Railway)
NODE_ENV=production
PORT=5000

# Neon pooled connection string (SSL required)
DATABASE_URL=postgresql://<user>:<password>@<host-pooler>/<db>?sslmode=require&channel_binding=require

JWT_SECRET=<replace-with-64-char-random-secret>
JWT_EXPIRES_IN=7d

FRONTEND_URL=https://math-intellect.vercel.app
CORS_ORIGIN=https://math-intellect.vercel.app

# Optional integrations
OPENAI_API_KEY=
REDIS_URL=
LOG_LEVEL=info
