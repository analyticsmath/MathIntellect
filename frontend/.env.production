# ─── Frontend Production Build-time Variables ────────────────────────────────
# These are baked into the Vite bundle at build time.
# VITE_* prefix is required for Vite to expose variables to the browser.

# When using Nginx proxy (frontend + backend on same domain):
VITE_API_URL=/api/v1
VITE_WS_URL=

# When backend is on a separate subdomain:
# VITE_API_URL=https://api.yourdomain.com/api/v1
# VITE_WS_URL=https://api.yourdomain.com
